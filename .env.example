# TSN-Affinity Environment Variables
# Copy this file to .env and fill in the values as needed.

# ── PyTorch ──────────────────────────────────────────────────────────────────
# Device to use for training: "cpu", "cuda", "cuda:0", etc.
# TORCH_DEVICE=cpu

# Enable CUDA flash attention (requires Ampere+ GPU)
# TORCH_ENABLE_FLASH_ATTENTION=0

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# ── Data ─────────────────────────────────────────────────────────────────────
# Root directory for storing benchmark results
# RESULTS_DIR=runs/

# Root directory for cached datasets
# DATA_DIR=data/
