# Auto detect text files and normalize line endings
* text=auto

# Python
*.py text diff=python
*.pyi text diff=python

# Markdown
*.md text diff=markdown

# Config
*.toml text
*.yml text
*.yaml text
*.json text

# Shell
*.sh text eol=lf
*.bash text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pth binary
*.pt binary
*.npy binary
*.npz binary
